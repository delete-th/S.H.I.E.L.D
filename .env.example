# Ollama (free & open-source LLM — replaces Claude)
# Run locally: `ollama pull mistral` then `ollama serve`
# Or use the ollama service in docker-compose
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=mistral

# App
